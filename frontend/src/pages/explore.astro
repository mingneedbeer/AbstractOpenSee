---
import MainLayout from "../layouts/MainLayout.astro";
import { NFTGrid } from "../components/NFTGrid";
---

<MainLayout>
  <section class="section">
    <h1 class="section-title">Explore NFTs</h1>
    <p class="page-subtitle">Discover unique digital assets on Abstract Testnet</p>
    <div style="margin-top: 24px">
      <NFTGrid client:load emptyMessage="No NFTs found" />
    </div>
  </section>
</MainLayout>

<style>
  .page-subtitle {
    font-size: 16px;
    color: var(--color-text-secondary);
    margin-top: -16px;
    margin-bottom: 8px;
  }
</style>
