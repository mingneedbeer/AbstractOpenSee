{
  "buildCommand": "cd frontend && bun install && bun run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && bun install",
  "framework": "astro",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://abstract-opensee-api.vercel.app/api/$1" }
  ],
  "github": {
    "silent": true
  }
}
